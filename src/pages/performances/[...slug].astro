---
import {getCollection, render, type CollectionEntry} from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {Image} from 'astro:assets';
import ogpImage from '../../assets/ogp.avif';

export async function getStaticPaths() {
    const performances = await getCollection('performances');
    const sorted = performances.sort((a: CollectionEntry<'performances'>, b: CollectionEntry<'performances'>) =>
        new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime()
    );
    return sorted.map((performance: CollectionEntry<'performances'>, index: number) => ({
        params: {slug: performance.id},
        props: {
            performance,
            prevPerformance: sorted[index + 1] ?? null,
            nextPerformance: sorted[index - 1] ?? null,
        },
    }));
}

const {performance, prevPerformance, nextPerformance} = Astro.props;
const {Content} = await render(performance);

const displayImage = performance.data.thumbnail ?? performance.data.flyer?.front ?? ogpImage;

const performanceData = {
    name: performance.data.name,
    startDate: new Date(performance.data.startDate).toISOString(),
    excerpt: performance.data.excerpt,
    image: displayImage.src,
    director: performance.data.director,
    offers: performance.data.offers?.map(offer => ({
        price: offer.price,
        priceCurrency: 'JPY'
    }))
};

const breadcrumbs = [
    {name: '公演', item: '/performances/'},
    {name: performance.data.name, item: Astro.url.pathname}
];
---

<Layout
        title={performance.data.name + " - 公演"}
        description={performance.data.excerpt}
        image={displayImage.src}
        type="article"
        schemaType="Event"
        schemaData={performanceData}
        breadcrumbs={breadcrumbs}
>
    <main>
        <article>
            <header class="container-md mt-5">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a class="breadcrumb-link" href="/">ホーム</a></li>
                    <li class="breadcrumb-item"><a class="breadcrumb-link" href="/performances/">公演</a></li>
                    <li class="breadcrumb-item">{performance.data.name}</li>
                </ol>
                <h1 class="h1 mb-2">{performance.data.name}</h1>
                <time datetime={new Date(performance.data.startDate).toISOString().split('T')[0]} class="">
                    {new Date(performance.data.startDate).toLocaleDateString('ja-JP', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    })}
                </time>
                <dl class="mt-2 d-flex flex-wrap">
                    <dt class="mr-2">作:</dt>
                    <dd class="mr-4">{performance.data.playwright}</dd>
                    <dt class="mr-2">演出:</dt>
                    <dd class="">{performance.data.director}</dd>
                </dl>
            </header>
            <div class="container-lg custom-performances-area mt-4">
                <div class="custom-performances-img">
                    {performance.data.flyer?.front && (
                            <Image
                                    src={performance.data.flyer.front}
                                    alt={`${performance.data.name} フライヤー表`}
                                    class="img-fluid"
                            />
                    )}
                    {performance.data.flyer?.back && (
                            <Image
                                    src={performance.data.flyer.back}
                                    alt={`${performance.data.name} フライヤー裏`}
                                    class="img-fluid mt-3"
                            />
                    )}
                    {!performance.data.flyer && performance.data.thumbnail && (
                            <Image
                                    src={performance.data.thumbnail}
                                    alt={performance.data.name}
                                    class="img-fluid"
                            />
                    )}
                </div>
                <div class="content custom-performances-content">
                    <Content/>
                </div>
            </div>
            <footer class="container-md mt-5 pb-6">
                <nav class="page-navigation flex-wrap">
                    {prevPerformance ? (
                            <a class="page-navigation-item prev vstack g-2"
                               href={`/performances/${prevPerformance.id}/`}>
                                <span class="mr-auto text-black fs-14 fw-n">{prevPerformance.data.category}</span>
                                <span class="mr-auto fs-16">{prevPerformance.data.name}</span>
                            </a>
                    ) : (
                            <span class="page-navigation-item-emp"></span>
                    )}
                    <a class="page-navigation-item"
                       href={`/performances/#${performance.data.startDate.getFullYear()}`}>
                        {performance.data.startDate.getFullYear()}年の公演一覧
                    </a>
                    {nextPerformance ? (
                            <a class="page-navigation-item next vstack g-2"
                               href={`/performances/${nextPerformance.id}/`}>
                                <span class="ml-auto text-black fs-14 fw-n">{nextPerformance.data.category}</span>
                                <span class="ml-auto fs-16">{nextPerformance.data.name}</span>
                            </a>
                    ) : (
                            <span class="page-navigation-item-emp"></span>
                    )}
                </nav>
            </footer>
        </article>
    </main>
</Layout>

<style lang="scss">
  .custom-performances-area {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    gap: 2.5rem;
    grid-template-areas:"img""content";
  }

  @media screen and (min-width: 768px) {
    .custom-performances-area {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr;
      gap: 2.5rem;
      grid-template-areas: "content img";
    }
    .custom-performances-img {
      grid-area: img;
    }
    .custom-performances-content {
      grid-area: content;
    }
  }
</style>
