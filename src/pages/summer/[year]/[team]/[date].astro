---
import {getCollection, render} from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';

export async function getStaticPaths() {
    const diaries = await getCollection('summerDiaries');
    const sorted = diaries.sort(
        (a, b) => a.data.date.getTime() - b.data.date.getTime()
    );

    return sorted.map((entry, index) => {
        const [year, team, date] = entry.id.split('/');

        const teamDiaries = sorted.filter(d => d.id.startsWith(`${year}/${team}/`));
        const teamIndex = teamDiaries.findIndex(d => d.id === entry.id);

        return {
            params: {year, team, date},
            props: {
                entry,
                prevEntry: teamIndex > 0 ? teamDiaries[teamIndex - 1] : null,
                nextEntry: teamIndex < teamDiaries.length - 1 ? teamDiaries[teamIndex + 1] : null,
            },
        };
    });
}

const {entry, prevEntry, nextEntry} = Astro.props;
const {year, team, date} = Astro.params;

const teams = await getCollection('summerTeams');
const teamInfo = teams.find(t => t.id === `${year}/${team}`);

const formatDate = (date: Date) => {
    return date.toLocaleDateString('ja-JP', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
};

const {Content} = await render(entry);

const breadcrumbs = [
    {name: '夏チーム', item: '/summer/'},
    {name: teamInfo?.data.name ?? team, item: `/summer/${year}/${team}/`},
    {name: entry.data.title, item: Astro.url.pathname}
];
---

<Layout
        title={`${entry.data.title} - ${teamInfo?.data.name ?? team}活動日記`}
        description={`${formatDate(entry.data.date)}の${teamInfo?.data.name ?? team}活動日記「${entry.data.title}」です。`}
        type="article"
        breadcrumbs={breadcrumbs}
        noindex={true}
>
    <main class="mt-5">
        <article>
            <header class="container-md">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a class="breadcrumb-link" href="/">ホーム</a></li>
                    <li class="breadcrumb-item"><a class="breadcrumb-link" href="/summer/">夏チーム</a></li>
                    <li class="breadcrumb-item">
                        <a class="breadcrumb-link" href={`/summer/${year}/${team}/`}>
                            {teamInfo?.data.name ?? team}
                        </a>
                    </li>
                    <li class="breadcrumb-item">{entry.data.title}</li>
                </ol>
                <h1 class="h1 mb-2">{entry.data.title}</h1>
                <div class="hstack g-3">
                    <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
                </div>
            </header>
            <div class="mt-4 content container-sm">
                <Content/>
                <hr class="mt-3 divider w-25">
            </div>
            <footer class="container-md mt-5 pb-6">
                <nav class="page-navigation flex-wrap">
                    {prevEntry ? (
                            <a class="page-navigation-item prev"
                               href={`/summer/${year}/${team}/${prevEntry.id.split('/')[2]}/`}>
                                {prevEntry.data.title}
                            </a>
                    ) : (
                            <span class="page-navigation-item-emp"></span>
                    )}
                    <a class="page-navigation-item" href={`/summer/${year}/${team}/`}> 一覧表示</a>
                    {nextEntry ? (
                            <a class="page-navigation-item next"
                               href={`/summer/${year}/${team}/${nextEntry.id.split('/')[2]}/`}>
                                {nextEntry.data.title}
                            </a>
                    ) : (
                            <span class="page-navigation-item-emp"></span>
                    )}
                </nav>
            </footer>
        </article>
    </main>
</Layout>
