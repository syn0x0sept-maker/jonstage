---
import {getCollection, render, type CollectionEntry} from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {Image} from 'astro:assets';
import ogpImage from '../../assets/ogp.avif';

//URLページの自動生成
export async function getStaticPaths() {
    //夏チームの全データをコレクションフォルダ内のsummer_teamsから取得
    const summerTeams = await getCollection('summer_teams');
    
    //年順に並び替え
    const sorted = summerTeams.sort((a: CollectionEntry<'summer_teams'>, b: CollectionEntry<'summer_teams'>) =>
        b.data.year - a.data.year
    );
    //チームごとにurlと、ページ内で使うデータを渡す
    return sorted.map((summer_team: CollectionEntry<'summer_teams'>, index: number) => ({
        params: {team: summer_team.id},
        props: {
            summer_team,//自分のデータ
            prevSummer_team: sorted[index + 1] ?? null,//前のチーム
            nextSummer_team: sorted[index - 1] ?? null,//次のチーム
        },
    }));
}

//getStaticPathsの受け取り
const {summer_team, prevSummer_team, nextSummer_team} = Astro.props;
//マークダウンの中身をhtmlとして表示できるよう変換
const {Content} = await render(summer_team);

//このチームの日記を取得
const allDiaries = await getCollection('summer_diary');
const teamDiaries = allDiaries
    //日記のid（年/team名/で絞る）
    .filter(diary => diary.id.startsWith(`${summer_team.id}/`))
    //日付順に並び替え
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    //日付を日本語に変換
    const formatDate = (date: Date) => {
        return date.toLocaleDateString('ja-JP',{
            year: 'numeric',
            month: 'long',
            day: 'numeric',
        });
    };

//サムネイル画像の取得
const displayImage = summer_team.data.thumbnail ?? ogpImage;

// const summer_teamData = {
//     name: summer_team.data.name,
//     startDate: new Date(summer_team.data.startDate).toISOString(),
//     excerpt: summer_team.data.excerpt,
//     image: displayImage.src,
//     director: summer_team.data.director,
//     offers: summer_team.data.offers?.map(offer => ({
//         price: offer.price,
//         priceCurrency: 'JPY'
//     }))
// };

//ぱんくずリスト
const breadcrumbs = [
    {name: '公演', item: '/summer/'},
    {name: summer_team.data.teamName, item: Astro.url.pathname}
];
---

<Layout
        title={summer_team.data.teamName + " - 公演"}
        description={summer_team.data.director}
        image={displayImage.src}
        type="article"
        breadcrumbs={breadcrumbs}
>
    <main>
        <article>
            <header class="container-md mt-5">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a class="breadcrumb-link" href="/summer/">夏チーム</a></li>
                    <li class="breadcrumb-item">{summer_team.data.teamName}</li>
                </ol>
                <h1 class="h1 mb-2">{summer_team.data.teamName}</h1>
                <time datetime={summer_team.data.year.toString()}>
                    {summer_team.data.year}年
                </time>
                <dl class="mt-2 d-flex flex-wrap">
                    <dt class="mr-2">演出:</dt>
                    <dd class="">{summer_team.data.director}</dd>
                </dl>
                <a class="link fw-bold" href={`https://www.instagram.com/${summer_team.data.instagram}/`}>instagram</a>
            </header>
            <div class="container-lg custom-summer_teams-area mt-4">
                <div class="content custom-summer_teams-content">
                    <Content/>
                </div>
            </div>

            <!-- 追加 -->
            <section class="container-md mt-5 pt-4" style="border-top: 1px solid #ddd;">
                <h2 class="h2 mb-4">チームの日記</h2>
                {teamDiaries.length > 0 ? (
                    <ul class="list-unstyled vstack g-3">
                        {teamDiaries.map(diary => {
                            //urlのために日付の形をyyyy-mm-ddに変換
                            const dateStr = diary.data.date.toISOString().split('T')[0];
                            return (
                                <li>
                                    <time class="d-inline-block mr-3 text-secondary" datetime={diary.data.date.toISOString()} style="width: 130px;">
                                        {formatDate(diary.data.date)}
                                    </time>
                                    <a class="link fw-bold" href={`/summer/${summer_team.id}/diary/${dateStr}/`}>
                                        {diary.data.title}
                                    </a>
                                </li>
                            );
                        })}
                    </ul>
                ) : (
                    <p class="text-muted">まだ日記はありません。</p>
                )}
            </section>

            <footer class="container-md mt-5 perf-footer">
                <nav class="perf-nav" aria-label="公演ナビゲーション">
                    <div class="perf-nav__prev">
                        {prevSummer_team && (
                            <a href={`/summer/${prevSummer_team.id}/`} class="perf-nav__link">
                                <span class="perf-nav__label">← 前の公演</span>
                                <span class="perf-nav__name">{prevSummer_team.data.teamName}</span>
                            </a>
                        )}
                    </div>
                    <a href="/summer/" class="btn btn-outline">公演一覧</a>
                    <div class="perf-nav__next">
                        {nextSummer_team && (
                            <a href={`/summer/${nextSummer_team.id}/`} class="perf-nav__link perf-nav__link--right">
                                <span class="perf-nav__label">次の公演 →</span>
                                <span class="perf-nav__name">{nextSummer_team.data.teamName}</span>
                            </a>
                        )}
                    </div>
                </nav>
            </footer>
        </article>
    </main>
</Layout>

<style lang="scss">
  .perf-footer {
    padding-bottom: 3rem;
  }

  .perf-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;

    &__prev {
      justify-self: start;
    }

    &__next {
      justify-self: end;
    }

    &__link {
      display: flex;
      flex-direction: column;
      gap: .25rem;
      text-decoration: none;
      color: inherit;
      padding: .5rem .75rem;
      border: 1px solid #949494;
      border-radius: 4px;
      transition: background .2s, color .2s;
      max-width: 200px;

      &:hover {
        background: #111;
        color: #fff;
        border-color: #111;
      }

      &--right {
        text-align: right;
      }
    }

    &__label {
      font-size: .75rem;
      opacity: .7;
    }

    &__name {
      font-size: .9rem;
      font-weight: 600;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
  }
</style>

<style lang="scss">
  .custom-summer_teams-area {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    gap: 2.5rem;
    grid-template-areas:"img""content";
  }

  @media screen and (min-width: 768px) {
    .custom-summer_teams-area {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr;
      gap: 2.5rem;
      grid-template-areas: "content img";
    }
    .custom-summer_teams-img {
      grid-area: img;
    }
    .custom-summer_teams-content {
      grid-area: content;
    }
  }
</style>
