---
import {Image} from 'astro:assets';//astrの画像コンポーネント
import {getCollection, type CollectionEntry} from 'astro:content';//コレクションの取得関数と、型定義をインポート
import NoIndexLayout from '../../layouts/NoIndexLayout.astro';//レイアウトをインポート
import ogpImage from '../../assets/ogp.avif';//記事に画像がない場合のデフォルト画像をインポート

//指定フォルダ内の全てのマークダウンを取得して格納
const allSummerTeams = await getCollection('summer_teams');

//yearに基づいてソート
const sortedSummerTeams = allSummerTeams.sort((a: CollectionEntry<'summer_teams'>, b: CollectionEntry<'summer_teams'>) => {
    return b.data.year - a.data.year;
});

//データを年毎にまとめる
const SummerTeamsByYear = sortedSummerTeams.reduce((acc: Record<number, CollectionEntry<'summer_teams'>[]>, summer_teams: CollectionEntry<'summer_teams'>) => {
    const year = summer_teams.data.year;
    if (!acc[year]) {
        acc[year] = [];
    }
    //その年に、チームを格納
    acc[year].push(summer_teams);
    return acc;
}, {} as Record<number, CollectionEntry<'summer_teams'>[]>);

//存在するとしの数字リストと、その並べ替え
const years = Object.keys(SummerTeamsByYear).map(Number).sort((a: number, b: number) => b - a);

// const itemListData = {
//     items: sortedSummerTeams.map(p => ({
//         url: `/summer/${p.id}/`
//     }))
// };

//ぱんくずリスト
const breadcrumbs = [
    {name: '夏チーム', item: '/summer/'}
];
---

<NoIndexLayout
        title="夏チーム"
        description="劇団万絵巻の2025年から現在までの夏チーム一覧です。"
        breadcrumbs={breadcrumbs}
>
    <main>
        <!-- ぱんくずリスト -->
        <section class="container-md mt-5">
            <ol class="breadcrumb mb-2">
                <!-- <li class="breadcrumb-item"><a class="breadcrumb-link" href="/">ホーム</a></li> -->
                <li class="breadcrumb-item">夏チーム</li>
            </ol>
            <h1 class="h1">夏チーム</h1>
        </section>
        <nav class="year-nav container-md">
            <div class="year-nav__inner">
                <ul class="year-nav__list" id="year-nav-list">
                    <!--上記で作成した年のリスト（years）をループして、ジャンプ用ボタンを生成-->
                    {years.map((year: number) => (
                        <li class="year-nav__item">
                            <a class="badge badge-outline" href={`#${year}`} data-year={year}>{year}</a>
                        </li>
                    ))}
                </ul>
            </div>
        </nav>
        {years.map((year: number) => (
                <section class="container-md mt-6 year-section" id={year.toString()}>
                    <h2 class="h2">{year}年</h2>
                    <div class="mt-5 vstack g-5">
                        {/* その年に該当するチームデータを取り出して、表示 */}
                        {SummerTeamsByYear[year].map((summer_team: CollectionEntry<'summer_teams'>) => (
                                <article class="custom-card">
                                    <div class="custom-card__data">
                                        <h3 class="h2">{summer_team.data.teamName}</h3>
                                        <div class="hstack g-3">
                                            <time datetime={summer_team.data.year.toString()}>
                                              劇団万絵巻{summer_team.data.year}年度夏季自主研究発表公演
                                            </time>
                                        </div>
                                        <div class="hstack g-3">
                                            <ul>
                                                <li>演出：{summer_team.data.director}</li>
                                            </ul>
                                        </div>
                                        <a class="btn btn-fill is-sm"
                                          href={`/summer/${summer_team.id}/`}>詳しくみる</a>
                                    </div>
                                    {/* 画像 */}
                                    <div class="custom-card__img-area">
                                        <Image class="custom-card__img"
                                          src={summer_team.data.thumbnail ?? ogpImage}
                                          alt={summer_team.data.teamName}/>
                                    </div>
                                </article>
                        ))}
                    </div>
                </section>
        ))}
        <section class="bg-grey-100 py-6 mt-6">
            <div class="container-sm">
                <h2 class="h2 mb-3">夏季自主研究発表公演</h2>
                <p class="mb-3">
                    夏季自主研究発表公演は、所属団員および顧問、OB、OG内での公演となっております。
                    <br>
                    夏チームアーカイブは2025年以降のみになります。
                    2024年以前は各チームのSNSおよびJUGEMUブログをご覧ください。
                </p>
            </div>
        </section>
    </main>
</NoIndexLayout>

<script>
  //各年の見出しエリアを全て取得
  const sections = document.querySelectorAll<HTMLElement>('.year-section');
  //上記のバッジを取得
  const links = document.querySelectorAll<HTMLAnchorElement>('.badge.badge-outline');

  //スクロールに合わせてナビゲーションの色を変える
  const setActive = (id: string) => {
    links.forEach(link => {
      //見ているセクションの年と一致しているリンクだけ、指定のクラスをつける
      link.classList.toggle('badge-fill', link.dataset.year === id);
    });
    //アクティブになったリンク（年）が自動で見えるように横スクロール
    const activeLink = document.querySelector<HTMLAnchorElement>(`.year-nav__link[data-year="${id}"]`);
    activeLink?.scrollIntoView({block: 'nearest', inline: 'center'});
  };

  const observer = new IntersectionObserver(
    entries => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
          break;
        }
      }
    },
    //アクティブ判定エリア
    {rootMargin: '-10% 0px -80% 0px', threshold: 0}
  );

  sections.forEach(section => observer.observe(section));
</script>

<style lang="scss">
  .year-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid #e0e0e0;
    margin-top: 2rem;

    &__inner {
      overflow-x: auto;
    }

    &__list {
      display: flex;
      flex-wrap: nowrap;
      gap: .5rem;
      list-style: none;
      margin: 0;
      padding: .625rem 1rem;
      width: max-content;
      min-width: 100%;
    }

    &__link {
      display: block;
      padding: .3rem .9rem;
      border: 1.5px solid #c0c0c0;
      border-radius: 2rem;
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .04em;
      text-decoration: none;
      color: #555;
      white-space: nowrap;
      transition: background .18s, color .18s, border-color .18s, transform .1s;

      &:hover {
        background: #111;
        color: #fff;
        border-color: #111;
        transform: translateY(-1px);
      }

      &.is-active {
        background: #111;
        color: #fff;
        border-color: #111;
      }
    }
  }

  .year-section {
    scroll-margin-top: 6rem;
  }

  .custom-card {
    border: 1px solid #949494;
    display: grid;
    grid-template-columns: .4fr 1fr;
    grid-template-rows: auto;
    grid-template-areas: "img data";

    &__img-area {
      grid-area: img;
      border-right: 1px solid #949494;
    }

    &__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__data {
      padding: 1rem 1.5rem;
      grid-area: data;
      display: flex;
      flex-direction: column;
      gap: .5rem;
    }
  }
</style>
