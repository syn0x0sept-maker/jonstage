---
import Layout from "../../layouts/Layout.astro";
import {Image} from "astro:assets";
import seisaku from '../../assets/welcome/seisaku_top.avif';
import kouhou from '../../assets/welcome/kouhou_top.avif';
import ishoumeik from '../../assets/welcome/ishoumeik_top.avif';
import kodougu from '../../assets/welcome/kodougu_top.avif';
import oodougu from '../../assets/welcome/oodougu_top.avif';
import shoumei from '../../assets/welcome/shoumei_top.avif';
import onkyou from '../../assets/welcome/onkyou_top.avif';
import butaikantoku from '../../assets/welcome/butaikantoku_top.avif';
import enshutu from '../../assets/welcome/enshutu_top.avif';
import okibira from '../../assets/welcome/okibira.avif';
import uragawa from '../../assets/welcome/uragawa.avif';
import mapS from '../../assets/welcome/map_s.avif';
---

<Layout title="2026年度新入生歓迎特集">
    <main>
        <section class="welcome-hero">
            <video class="welcome-video" autoplay loop muted playsinline>
                <!-- Chrome / Firefox / Edge: WebM(AV1) -->
                <source src="/welcome/welcome.webm" type="video/webm; codecs=av01"/>
                <!-- Safari: MP4(H.264) -->
                <source src="/welcome/welcome.mp4" type="video/mp4"/>
            </video>
            <h1 class="hero-text">舞台でしか<br/>出会えない顔がある</h1>
        </section>
        <section class="container-lg mt-6">
            <h2 class="h2">私たちについて</h2>
            <p class="mt-3">年間5～6回の公演を中心に各イベントごとのパーティやキャンプ、スキー旅行など、学内学外問わずあらゆる活動を心ゆくまで満喫している演劇サークルです。
                人数は例年40人ほど。この高槻キャンパス内では比較的大きく、サークル内の結束も強く生まれる人数です。毎年、学内の施設を借りたり学外では大阪府内の小劇場やホールを借りて演劇を上演しています。また人によってはサークル以外の大きな劇団の公演に参加する人も。関西大学統一学園祭では関西大学にある4つの演劇サークル・演劇部でユニットを組みお芝居をするなど、高槻キャンパスを超えた活動をしています。みんなで考えながら協力し合って一つのお芝居を作ることに全力を注いでいます!
                芝居する時は徹底的に芝居する、遊ぶときは徹底的に遊ぶ。高槻キャンパスでこれほど活発に活動している団体は他にいないのではないでしょうか?<br>
                <br>万絵巻にご興味のある方は、お気軽にS棟までお越しください。
            </p>
        </section>
        <section class="container-lg mt-5 mb-6">
            <ul class="d-flex g-3 flex-wrap">
                <li><a class="link" href="#役職体験会">役職体験会</a></li>
                <li><a class="link" href="#新入生歓迎公演">新入生歓迎公演</a></li>
                <li><a class="link" href="#万の人から聞いたウラガワ">万の人から聞いたウラガワ</a></li>
                <li><a class="link" href="#役職紹介">役職紹介</a></li>
            </ul>
        </section>
        <section class="container-lg my-6">
            <h2 class="h2 mb-4" id="役職体験会">役職体験会</h2>
            <p class="mb-3 mt-3">演劇は役者だけじゃない。大道具・音響・広報…他にもたくさんの役職が公演を支えています。 そんなスタッフをちょっとのぞいてみませんか？</p>
            <ol class="taiken-list">
                <li class="taiken-item">
                    <strong class="taiken-role"><a class="link" href="#大道具">大道具</a></strong>
                    <div class="taiken-schedule">
                        <time class="taiken-date" datetime="2026-04-20">4月20日(月)</time>
                        <span class="badge badge-filled-outline">昼休み</span>
                    </div>
                </li>
                <li class="taiken-item">
                    <strong class="taiken-role"><a class="link" href="#小道具">小道具</a></strong>
                    <div class="taiken-schedule">
                        <time class="taiken-date" datetime="2026-04-21">4月21日(火)</time>
                        <span class="badge badge-filled-outline">昼休み</span>
                    </div>
                </li>
                <li class="taiken-item">
                    <strong class="taiken-role"><a class="link" href="#音響">音響</a></strong>
                    <div class="taiken-schedule">
                        <time class="taiken-date" datetime="2026-04-22">4月22日(水)</time>
                        <span class="badge badge-filled-outline">昼休み</span>
                    </div>
                </li>
                <li class="taiken-item">
                    <strong class="taiken-role"><a class="link" href="#照明">照明</a></strong>
                    <div class="taiken-schedule">
                        <time class="taiken-date" datetime="2026-04-23">4月23日(木)</time>
                        <span class="badge badge-filled-outline">昼休み</span>
                    </div>
                </li>
                <li class="taiken-item">
                    <strong class="taiken-role"><a class="link" href="#広報">広報</a></strong>
                    <div class="taiken-schedule">
                        <time class="taiken-date" datetime="2026-04-24">4月24日(金)</time>
                        <span class="badge badge-filled-outline">昼休み</span>
                    </div>
                </li>
                <li class="taiken-item">
                    <strong class="taiken-role"><a class="link" href="#衣装">衣装</a></strong>
                    <div class="taiken-schedule">
                        <time class="taiken-date" datetime="2026-04-27">4月27日(月)</time>
                        <span class="badge badge-filled-outline">昼休み</span>
                    </div>
                </li>
            </ol>
            <figure class="taiken-map">
                <figcaption class="fs-24">開催場所：S棟</figcaption>
                <Image class="img-fluid" src={mapS} alt="役職体験会の開催場所 S棟の地図"/>
            </figure>
        </section>
        <section class="container-lg my-6">
            <h2 class="h2 mb-3" id="新入生歓迎公演">新入生歓迎公演</h2>
            <a class="link" href="/performances/2026/itiaku/">関西大学演劇サークル劇団万絵巻2026年度新入生歓迎公演『一握の石』</a>
            <Image class="img-fluid w-100" src={okibira} alt=""/>
        </section>
        <section class="container-lg my-6">
            <h2 class="h2 mb-3" id="万の人から聞いたウラガワ">万の人から聞いたウラガワ</h2>
            <Image class="img-fluid w-100" src={uragawa} alt=""/>
        </section>
        <section class="container-lg my-6">
            <h2 class="h2" id="役職紹介">役職紹介</h2>
            <div class="vstack g-5">
                <div class="grid g-3">
                    <div class="content col-12 col-md-6">
                        <h3>制作</h3>
                        <p>公演の根底を支える事務的存在</p>
                        <p>
                            広報と連携してどの媒体にどの情報を載せ宣伝するか考えたり、本番の受付や案内係などのスタッフ業務を行う役職であり、公演中だけではなく、公演前後のたくさんのお仕事も担う役割を持つ！</p>
                        <p>裏方として誰かをサポートしたい方に向いております！</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={seisaku} alt=""/>
                    </div>
                </div>
                <div class="grid g-3">
                    <div class="content col-12 col-md-6" id="広報">
                        <h3>広報</h3>
                        <p>宣伝のためのチラシやパンフレットなどを作る役職！</p>
                        <p>
                            個人での作業が多く、自分のペースで楽しめます。コンピュータースキルを上げたい人や、写真･デザイン･イラストが好きな人にオススメ！</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={kouhou} alt=""/>
                    </div>
                </div>
                <div class="grid g-3">
                    <div class="content col-12 col-md-6" id="衣装">
                        <h3>衣装</h3>
                        <p>
                            衣装のイメージを演出と共有し、衣装作りやコーディネート、本番当日は舞台メイクやヘアセットをして役者が舞台で輝けるよう手助けします！</p>
                        <p>コーディネートや裁縫が好きな人はもちろん
                            メイクしたことない、センスに自信がないという人でも大丈夫！男性も大歓迎です‼︎</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={ishoumeik} alt=""/>
                    </div>
                </div>
                <div class="grid g-3">
                    <div class="content col-12 col-md-6" id="小道具">
                        <h3>小道具</h3>
                        <p>～役者の使う道具を作る職人～</p>
                        <p>役者が劇中で使う道具を用意する役職！</p>
                        <p>
                            銃火器などの武器を作ることも。強度や耐久性、使いやすさを考え、装飾にもこだわりをもち、丁寧に仕上げていく様はまさに職人！器用な人や細かい作業が好きな人にオススメ！</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={kodougu} alt=""/>
                    </div>
                </div>
                <div class="grid g-3">
                    <div class="content col-12 col-md-6" id="大道具">
                        <h3>大道具</h3>
                        <p>舞台のことならなんでもお任せください！</p>
                        <p>大道具に入ればみんな大工さんに！</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={oodougu} alt=""/>
                    </div>
                </div>
                <div class="grid g-3">
                    <div class="content col-12 col-md-6" id="照明">
                        <h3>照明</h3>
                        <p>舞台の明かりを作る役職！</p>
                        <p>
                            明かりによって舞台の雰囲気が変わったり、役者のモチベーションも上がって演技に深みが出たりするので、お芝居を作る上でとっても重要。専門の用語が多く、かっこいいところも魅力！</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={shoumei} alt=""/>
                    </div>
                </div>
                <div class="grid g-3">
                    <div class="content col-12 col-md-6" id="音響">
                        <h3>音響</h3>
                        <p>シーンに合ったBGMや効果音(SE)を探す，その名のとおり『音で舞台を彩る役職』です。</p>
                        <p>
                            実際に本番で音を鳴らす人員もいます。舞台に立つのは自信ないけど本番に関わりたい気持ちはある方是非</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={onkyou} alt=""/>
                    </div>
                </div>
                <div class="grid g-3">
                    <div class="content col-12 col-md-6">
                        <h3>舞台監督</h3>
                        <p>ー全体を統括する現場の最高責任者ー</p>
                        <p>
                            主な仕事はスケジュール管理などのスタッフの統括！舞台監督には全体を観察する力や、状況を冷静に判断する力が必要不可欠。非常に責任のある役職ですが、公演後には大きな充実感と達成感を味わえます！！</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={butaikantoku} alt=""/>
                    </div>
                </div>
                <div class="grid g-3">
                    <div class="content col-12 col-md-6">
                        <h3>演出</h3>
                        <p>
                            舞台の全てを司るといっても過言ではない演出。全ての役職と連携を取りながら舞台を創りあげていきます。責任重大で大変な仕事ですが自分にとって大きな経験値になること間違いなしです。</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <Image class="img-fluid" src={enshutu} alt=""/>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style lang="scss">
  .welcome-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-text {
    text-align: center;
    color: white;
    font-weight: bold;
    position: absolute;
    font-size: 2.8rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 0, 0, 0.4);
  }

  .welcome-video {
    display: block;
    width: 100%;
    height: calc(100dvh - 69px);
    object-fit: cover;
    pointer-events: none;
  }

  @media screen and (min-width: 768px) {
    .welcome-video {
      height: calc(100dvh - 136px);
    }
  }

  .taiken-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;

    @media screen and (min-width: 576px) {
      grid-template-columns: repeat(3, 1fr);
    }

    @media screen and (min-width: 992px) {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .taiken-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1rem;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-top: 3px solid currentColor;
    border-radius: 6px;
    background-color: #fff;
  }

  .taiken-role {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .taiken-schedule {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: 0.2rem;
  }

  .taiken-date {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .taiken-time {
    font-size: 0.8rem;
    color: #666;
    background-color: #f3f3f3;
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    align-self: flex-start;
  }

  .taiken-map {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;

    img {
      border-radius: 6px;
      max-width: 480px;
      width: 100%;
    }

    figcaption {
    }
  }
</style>
