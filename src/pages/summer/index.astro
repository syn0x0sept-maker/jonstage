---
import {Image} from 'astro:assets';
import {getCollection, type CollectionEntry} from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ogpImage from '../../assets/ogp.avif';

const summerTeams = await getCollection('summerTeams');

const teamsByYear = summerTeams.reduce((acc: Record<number, CollectionEntry<'summerTeams'>[]>, team) => {
    const year = team.data.year;
    if (!acc[year]) {
        acc[year] = [];
    }
    acc[year].push(team);
    return acc;
}, {} as Record<number, CollectionEntry<'summerTeams'>[]>);

const years = Object.keys(teamsByYear).map(Number).sort((a, b) => b - a);

const breadcrumbs = [
    {name: '夏チーム', item: '/summer/'}
];
---

<Layout
        title="夏チーム"
        description="劇団万絵巻の2025年から現在までの夏チーム一覧です。"
        breadcrumbs={breadcrumbs}
>
    <main>
        <section class="container-md mt-5">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a class="breadcrumb-link" href="/">ホーム</a></li>
                <li class="breadcrumb-item">夏チーム</li>
            </ol>
            <h1 class="h1">夏チーム</h1>
        </section>
        <nav class="year-nav container-md">
            <div class="year-nav__inner">
                <ul class="year-nav__list" id="year-nav-list">
                    {years.map((year) => (
                            <li class="year-nav__item">
                                <a class="badge badge-outline" href={`#${year}`} data-year={year}>{year}</a>
                            </li>
                    ))}
                </ul>
            </div>
        </nav>
        {years.map((year: number) => (
                <section class="container-md mt-6 year-section" id={year.toString()}>
                    <h2 class="h2">{year}年</h2>
                    <div class="mt-5 vstack g-5">
                        {teamsByYear[year].map((team: CollectionEntry<'summerTeams'>) => (
                                <article class="custom-card">
                                    <div class="custom-card__data">
                                        <h3 class="h2">{team.data.name}</h3>
                                        <div class="hstack g-3">
                                            <span>{year}年 夏チーム</span>
                                        </div>
                                        <div class="mt-3">
                                            <ul>
                                                {team.data.director &&
                                                        <li>演出：{team.data.director}</li>}
                                            </ul>
                                        </div>
                                        <div class="hstack g-3 mt-auto">
                                            {team.data.twitter && (
                                                    <a href={team.data.twitter} class="btn btn-outline is-sm"
                                                       target="_blank" rel="noopener noreferrer">
                                                        X (Twitter)
                                                    </a>
                                            )}
                                            {team.data.instagram && (
                                                    <a href={team.data.instagram} class="btn btn-outline is-sm"
                                                       target="_blank" rel="noopener noreferrer">
                                                        Instagram
                                                    </a>
                                            )}
                                        </div>
                                    </div>
                                    <div class="custom-card__img-area">
                                        <Image class="custom-card__img"
                                               src={team.data.thumbnail ?? ogpImage}
                                               alt={team.data.name}/>
                                    </div>
                                </article>
                        ))}
                    </div>
                </section>
        ))}
        <section class="bg-grey-100 py-6 mt-6">
            <div class="container-sm">
                <h2 class="h2 mb-3">夏季自主研究発表公演</h2>
                <p class="mb-3">
                    夏季自主研究発表公演は、所属団員および顧問、OB、OG内での公演となっております。
                    <br>
                    夏チームアーカイブは2025年以降のみになります。
                    2024年以前は各チームのSNSおよびJUGEMUブログをご覧ください。
                </p>
            </div>
        </section>
    </main>
</Layout>

<script>
    const sections = document.querySelectorAll<HTMLElement>('.year-section');
    const links = document.querySelectorAll<HTMLAnchorElement>('.badge.badge-outline');

    const setActive = (id: string) => {
        links.forEach(link => {
            link.classList.toggle('badge-fill', link.dataset.year === id);
        });
        const activeLink = document.querySelector<HTMLAnchorElement>(`.badge.badge-outline[data-year="${id}"]`);
        activeLink?.scrollIntoView({block: 'nearest', inline: 'center'});
    };

    const observer = new IntersectionObserver(
        entries => {
            for (const entry of entries) {
                if (entry.isIntersecting) {
                    setActive(entry.target.id);
                    break;
                }
            }
        },
        {rootMargin: '-10% 0px -80% 0px', threshold: 0}
    );

    sections.forEach(section => observer.observe(section));
</script>

<style lang="scss">
  .year-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid #e0e0e0;
    margin-top: 2rem;

    &__inner {
      overflow-x: auto;
    }

    &__list {
      display: flex;
      flex-wrap: nowrap;
      gap: .5rem;
      list-style: none;
      margin: 0;
      padding: .625rem 1rem;
      width: max-content;
      min-width: 100%;
    }
  }

  .year-section {
    scroll-margin-top: 6rem;
  }

  .custom-card {
    border: 1px solid #949494;
    display: grid;
    grid-template-columns: .4fr 1fr;
    grid-template-rows: auto;
    grid-template-areas: "img data";

    &__img-area {
      grid-area: img;
      border-right: 1px solid #949494;
    }

    &__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__data {
      padding: 1rem 1.5rem;
      grid-area: data;
      display: flex;
      flex-direction: column;
      gap: .5rem;
    }
  }
</style>
