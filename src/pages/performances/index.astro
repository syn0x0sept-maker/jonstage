---
import {Image} from 'astro:assets';
import {getCollection, type CollectionEntry} from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ogpImage from '../../assets/ogp.avif';

const allPerformances = await getCollection('performances');

const sortedPerformances = allPerformances.sort((a: CollectionEntry<'performances'>, b: CollectionEntry<'performances'>) => {
    return new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime();
});

const performancesByYear = sortedPerformances.reduce((acc: Record<number, CollectionEntry<'performances'>[]>, performance: CollectionEntry<'performances'>) => {
    const date = new Date(performance.data.startDate);
    const year = date.getFullYear();
    if (!acc[year]) {
        acc[year] = [];
    }
    acc[year].push(performance);
    return acc;
}, {} as Record<number, CollectionEntry<'performances'>[]>);

const years = Object.keys(performancesByYear).map(Number).sort((a: number, b: number) => b - a);

const itemListData = {
    items: sortedPerformances.map(p => ({
        url: `/performances/${p.id}/`
    }))
};

const breadcrumbs = [
    {name: '公演', item: '/performances/'}
];
---

<Layout
        title="公演"
        description="劇団万絵巻の過去から現在までの公演一覧です。1994年の設立以来、様々な作品を上演してきました。"
        schemaType="ItemList"
        schemaData={itemListData}
        breadcrumbs={breadcrumbs}
>
    <main>
        <section class="container-md mt-5">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a class="breadcrumb-link" href="/">ホーム</a></li>
                <li class="breadcrumb-item">公演</li>
            </ol>
            <h1 class="h1">公演</h1>
        </section>
        <nav class="year-nav">
            <div class="year-nav__inner">
                <ul class="year-nav__list" id="year-nav-list">
                    {years.map((year: number) => (
                        <li class="year-nav__item">
                            <a class="year-nav__link" href={`#${year}`} data-year={year}>{year}</a>
                        </li>
                    ))}
                </ul>
            </div>
        </nav>
        {years.map((year: number) => (
                <section class="container-md mt-6 year-section" id={year.toString()}>
                    <h2 class="h2">{year}年</h2>
                    <div class="mt-5 vstack g-5">
                        {performancesByYear[year].map((performance: CollectionEntry<'performances'>) => (
                                <article class="custom-card">
                                    <div class="custom-card__data">
                                        <h3 class="h2">{performance.data.name}</h3>
                                        <div class="hstack g-3">
                                            <time datetime={new Date(performance.data.startDate).toISOString().split('T')[0]}>
                                                {new Date(performance.data.startDate).toLocaleDateString('ja-JP', {
                                                    year: 'numeric',
                                                    month: 'long',
                                                    day: 'numeric'
                                                })}
                                            </time>
                                            <span>{performance.data.category}</span>
                                        </div>
                                        <p>{performance.data.excerpt}</p>
                                        <div class="hstack g-3">
                                            <ul>
                                                <li>作：{performance.data.playwright}</li>
                                                <li>演出：{performance.data.director}</li>
                                            </ul>
                                        </div>
                                        <a class="btn btn-fill is-sm"
                                           href={`/performances/${performance.id}/`}>詳しくみる</a>
                                    </div>
                                    <div class="custom-card__img-area">
                                        <Image class="custom-card__img"
                                               src={performance.data.thumbnail ?? performance.data.flyer?.front ?? ogpImage}
                                               alt={performance.data.name}/>
                                    </div>
                                </article>
                        ))}
                    </div>
                </section>
        ))}
        <section class="bg-grey-100 py-6 mt-6">
            <div class="container-sm">
                <h2 class="h2 mb-3">私たちの公演の歴史</h2>
                <p class="mb-3">
                    1994年の劇団設立以来、古典的な作品から現代的な作品まで、様々な舞台を制作してきました。このアーカイブは、多様なストーリーテリングと芸術的な卓越性への私たちの取り組みを表しています。
                </p>
                <p class="">
                    公演履歴の詳細情報や、研究目的のためのアーカイブ資料のリクエストについては、
                    <a href="/contact/" class="link">お問い合わせ</a>ください。
                </p>
            </div>
        </section>
    </main>
</Layout>

<script>
  const sections = document.querySelectorAll<HTMLElement>('.year-section');
  const links = document.querySelectorAll<HTMLAnchorElement>('.year-nav__link');

  const setActive = (id: string) => {
    links.forEach(link => {
      link.classList.toggle('is-active', link.dataset.year === id);
    });
    const activeLink = document.querySelector<HTMLAnchorElement>(`.year-nav__link[data-year="${id}"]`);
    activeLink?.scrollIntoView({block: 'nearest', inline: 'center'});
  };

  const observer = new IntersectionObserver(
    entries => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
          break;
        }
      }
    },
    {rootMargin: '-10% 0px -80% 0px', threshold: 0}
  );

  sections.forEach(section => observer.observe(section));
</script>

<style lang="scss">
  .year-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, .92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid #e0e0e0;
    margin-top: 2rem;

    &__inner {
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      &::-webkit-scrollbar { display: none; }
    }

    &__list {
      display: flex;
      flex-wrap: nowrap;
      gap: .375rem;
      list-style: none;
      margin: 0;
      padding: .625rem 1rem;
      width: max-content;
      min-width: 100%;
    }

    &__link {
      display: block;
      padding: .3rem .9rem;
      border: 1.5px solid #c0c0c0;
      border-radius: 2rem;
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .04em;
      text-decoration: none;
      color: #555;
      white-space: nowrap;
      transition: background .18s, color .18s, border-color .18s, transform .1s;

      &:hover {
        background: #111;
        color: #fff;
        border-color: #111;
        transform: translateY(-1px);
      }

      &.is-active {
        background: #111;
        color: #fff;
        border-color: #111;
      }
    }
  }

  .year-section {
    scroll-margin-top: 3rem;
  }

  .custom-card {
    border: 1px solid #949494;
    display: grid;
    grid-template-columns: .4fr 1fr;
    grid-template-rows: auto;
    grid-template-areas: "img data";

    &__img-area {
      grid-area: img;
      border-right: 1px solid #949494;
    }

    &__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__data {
      padding: 1rem 1.5rem;
      grid-area: data;
      display: flex;
      flex-direction: column;
      gap: .5rem;
    }
  }
</style>
